#!/usr/bin/env bash
set -euo pipefail

default_version='@MILLI_DEFAULT_VERSION@'
version_file='.mill-interceptor-version'
config_version_file='.config/mill-interceptor-version'
mode="${MILLI_LAUNCHER_MODE:-auto}"
preferred_source="${MILLI_LAUNCHER_SOURCE:-maven}"
use_netrc="${MILLI_LAUNCHER_USE_NETRC:-0}"
dry_run="${MILLI_LAUNCHER_DRY_RUN:-0}"
cache_root="${MILLI_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/milli}"
dist_artifact='milli-dist'
dist_release_name='mill-interceptor-dist'
github_release_base='https://github.com/Eleven19/mill-interceptor/releases/download'

if [[ -n "${MILLI_VERSION:-}" ]]; then
  version="$MILLI_VERSION"
elif [[ -f "$version_file" ]]; then
  version="$(tr '\r' '\n' <"$version_file" | head -n 1)"
elif [[ -f "$config_version_file" ]]; then
  version="$(tr '\r' '\n' <"$config_version_file" | head -n 1)"
else
  version="$default_version"
fi

if [[ "$mode" != "auto" && "$mode" != "native" && "$mode" != "dist" ]]; then
  printf 'Unsupported MILLI_LAUNCHER_MODE: %s\n' "$mode" >&2
  exit 1
fi

if [[ "$preferred_source" != "maven" && "$preferred_source" != "github" ]]; then
  printf 'Unsupported MILLI_LAUNCHER_SOURCE: %s\n' "$preferred_source" >&2
  exit 1
fi

if [[ "$preferred_source" == "maven" ]]; then
  source_order=(maven github)
else
  source_order=(github maven)
fi

curl_netrc_flag=''
wget_netrc_flag=''
if [[ "$use_netrc" == "1" ]]; then
  curl_netrc_flag='--netrc'
  wget_netrc_flag='--netrc'
fi

native_supported='0'
native_artifact=''
native_release_target=''
native_archive_extension=''

case "$(uname -s):$(uname -m)" in
  Linux:x86_64)
    native_supported='1'
    native_artifact='milli-native-linux-amd64'
    native_release_target='x86_64-unknown-linux-gnu'
    native_archive_extension='tar.gz'
    ;;
  Linux:aarch64 | Linux:arm64)
    native_supported='1'
    native_artifact='milli-native-linux-aarch64'
    native_release_target='aarch64-unknown-linux-gnu'
    native_archive_extension='tar.gz'
    ;;
  Darwin:x86_64)
    native_supported='1'
    native_artifact='milli-native-macos-amd64'
    native_release_target='x86_64-apple-darwin'
    native_archive_extension='tar.gz'
    ;;
  Darwin:arm64)
    native_supported='1'
    native_artifact='milli-native-macos-aarch64'
    native_release_target='aarch64-apple-darwin'
    native_archive_extension='tar.gz'
    ;;
esac

dist_name="${dist_artifact}-${version}.jar"
dist_path="${cache_root}/${version}/${dist_name}"
dist_maven_url="https://repo1.maven.org/maven2/io/github/eleven19/mill-interceptor/${dist_artifact}/${version}/${dist_name}"
dist_github_url="${github_release_base}/v${version}/${dist_release_name}-v${version}.jar"

native_archive_name=''
native_path=''
native_archive_path=''
native_maven_url=''
native_github_url=''

if [[ "$native_supported" == "1" ]]; then
  native_archive_name="${native_artifact}-${version}.${native_archive_extension}"
  native_archive_path="${cache_root}/${version}/${native_archive_name}"
  native_path="${cache_root}/${version}/${native_artifact}/mill-interceptor"
  native_maven_url="https://repo1.maven.org/maven2/io/github/eleven19/mill-interceptor/${native_artifact}/${version}/${native_archive_name}"
  native_github_url="${github_release_base}/v${version}/mill-interceptor-v${version}-${native_release_target}.${native_archive_extension}"
fi

if [[ "$mode" == "auto" ]]; then
  if [[ "$native_supported" == "1" ]]; then
    mode_order=(native dist)
  else
    mode_order=(dist)
  fi
else
  mode_order=("$mode")
fi

join_by() {
  local delimiter="$1"
  shift
  local first='1'
  for item in "$@"; do
    if [[ "$first" == '1' ]]; then
      printf '%s' "$item"
      first='0'
    else
      printf '%s%s' "$delimiter" "$item"
    fi
  done
}

download_file() {
  local url="$1"
  local destination="$2"
  local temp_file="${destination}.tmp"

  mkdir -p "$(dirname "$destination")"

  if command -v curl >/dev/null 2>&1; then
    if [[ -n "$curl_netrc_flag" ]]; then
      curl -fsSL "$curl_netrc_flag" "$url" -o "$temp_file"
    else
      curl -fsSL "$url" -o "$temp_file"
    fi
  elif command -v wget >/dev/null 2>&1; then
    if [[ -n "$wget_netrc_flag" ]]; then
      wget -q "$wget_netrc_flag" -O "$temp_file" "$url"
    else
      wget -q -O "$temp_file" "$url"
    fi
  else
    printf 'Error: curl or wget is required to download milli artifacts\n' >&2
    exit 1
  fi

  mv -f "$temp_file" "$destination"
}

ensure_native() {
  local source="$1"
  local url=''
  local extract_dir=''

  if [[ "$native_supported" != "1" ]]; then
    return 1
  fi

  if [[ -x "$native_path" ]]; then
    return 0
  fi

  if [[ "$source" == 'maven' ]]; then
    url="$native_maven_url"
  else
    url="$native_github_url"
  fi

  if ! download_file "$url" "$native_archive_path"; then
    rm -f "$native_archive_path.tmp"
    return 1
  fi

  extract_dir="$(dirname "$native_path")"
  rm -rf "$extract_dir"
  mkdir -p "$extract_dir"

  if ! tar -xzf "$native_archive_path" -C "$extract_dir"; then
    return 1
  fi

  chmod +x "$native_path"
}

ensure_dist() {
  local source="$1"
  local url=''

  if [[ -f "$dist_path" ]]; then
    return 0
  fi

  if [[ "$source" == 'maven' ]]; then
    url="$dist_maven_url"
  else
    url="$dist_github_url"
  fi

  download_file "$url" "$dist_path"
}

if [[ "$dry_run" == '1' ]]; then
  printf 'version=%s\n' "$version"
  printf 'mode=%s\n' "$mode"
  printf 'mode_order=%s\n' "$(join_by ',' "${mode_order[@]}")"
  printf 'preferred_source=%s\n' "$preferred_source"
  printf 'source_order=%s\n' "$(join_by ',' "${source_order[@]}")"
  printf 'use_netrc=%s\n' "$use_netrc"
  printf 'curl_netrc_flag=%s\n' "$curl_netrc_flag"
  printf 'native_supported=%s\n' "$native_supported"
  if [[ "$native_supported" == '1' ]]; then
    printf 'native_artifact=%s\n' "$native_artifact"
    printf 'native_release_target=%s\n' "$native_release_target"
    printf 'native_maven_url=%s\n' "$native_maven_url"
    printf 'native_github_url=%s\n' "$native_github_url"
    printf 'native_path=%s\n' "$native_path"
  fi
  printf 'dist_artifact=%s\n' "$dist_artifact"
  printf 'dist_maven_url=%s\n' "$dist_maven_url"
  printf 'dist_github_url=%s\n' "$dist_github_url"
  printf 'dist_path=%s\n' "$dist_path"
  exit 0
fi

if [[ "$mode" == 'native' && "$native_supported" != '1' ]]; then
  printf 'No native milli artifact is available for this platform\n' >&2
  exit 1
fi

for candidate_mode in "${mode_order[@]}"; do
  if [[ "$candidate_mode" == 'native' ]]; then
    for source in "${source_order[@]}"; do
      if ensure_native "$source"; then
        exec "$native_path" "$@"
      fi
    done
  else
    for source in "${source_order[@]}"; do
      if ensure_dist "$source"; then
        exec java -jar "$dist_path" "$@"
      fi
    done
  fi
done

if [[ "$mode" == 'native' ]]; then
  printf 'Unable to download a native milli artifact for version %s from Maven Central or GitHub Releases\n' "$version" >&2
else
  printf 'Unable to download a milli dist artifact for version %s from Maven Central or GitHub Releases\n' "$version" >&2
fi

exit 1
